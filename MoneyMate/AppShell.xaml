<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MoneyMate.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MoneyMate"
    xmlns:auth="clr-namespace:MoneyMate.Views.Auth"
    xmlns:dashboard="clr-namespace:MoneyMate.Views.Dashboard"
    Title="Money Mate"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">

    <FlyoutItem x:Name="HomeFlyoutItem" Title="Accueil" FlyoutItemIsVisible="False">
        <ShellContent Title="Accueil" ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem x:Name="DashboardFlyoutItem" Title="Tableau de Bord" FlyoutItemIsVisible="False">
        <ShellContent Title="Dashboard" ContentTemplate="{DataTemplate dashboard:DashboardPage}" Route="DashboardPage" />
    </FlyoutItem>

    <FlyoutItem x:Name="LoginFlyoutItem" Title="Connexion" FlyoutItemIsVisible="False">
        <ShellContent Title="Connexion" ContentTemplate="{DataTemplate auth:LoginPage}" Route="LoginPage" />
    </FlyoutItem>

    <FlyoutItem x:Name="RegisterFlyoutItem" Title="Inscription" FlyoutItemIsVisible="False">
        <ShellContent Title="Inscription" ContentTemplate="{DataTemplate auth:RegisterPage}" Route="RegisterPage" />
    </FlyoutItem>

</Shell>
