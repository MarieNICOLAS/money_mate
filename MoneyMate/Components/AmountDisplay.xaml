<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MoneyMate.Components.AmountDisplay"
             x:Name="this">

    <Label x:Name="AmountLabel"
           Text="{Binding Source={x:Reference this}, Path=FormattedAmount}"
           FontSize="{Binding Source={x:Reference this}, Path=FontSize}"
           FontFamily="Lora"
           FontAttributes="Bold"
           TextColor="{Binding Source={x:Reference this}, Path=TextColor}"
           VerticalOptions="Center"
           HorizontalOptions="Start" />

</ContentView>
