<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MoneyMate.Components.AuthenticatedFooter"
             x:Name="this"
             BackgroundColor="Transparent"
             Margin="0">

    <Grid Padding="12,0,12,10"
          HeightRequest="86">
        <Border BackgroundColor="{StaticResource CardBackground}"
                Stroke="#D6E1EA"
                StrokeThickness="1"
                Padding="10,9"
                VerticalOptions="End">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#22000000"
                        Offset="0,8"
                        Radius="18"
                        Opacity="0.22" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,76,*,*,*"
                  ColumnSpacing="2"
                  HorizontalOptions="Fill"
                  HeightRequest="58">

                <VerticalStackLayout Grid.Column="0"
                                     Style="{StaticResource BottomNavItemStyle}">
                    <Label Text="{StaticResource IconHome}" Style="{StaticResource BottomNavIconStyle}" />
                    <Label Text="Accueil" Style="{StaticResource BottomNavLabelStyle}" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={x:Reference this}, Path=GoHomeCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1"
                                     Style="{StaticResource BottomNavItemStyle}">
                    <Label Text="{StaticResource IconExpense}" Style="{StaticResource BottomNavIconStyle}" />
                    <Label Text="Dépenses" Style="{StaticResource BottomNavLabelStyle}" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={x:Reference this}, Path=GoExpensesCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3"
                                     Style="{StaticResource BottomNavItemStyle}">
                    <Label Text="{StaticResource IconBudget}" Style="{StaticResource BottomNavIconStyle}" />
                    <Label Text="Budgets" Style="{StaticResource BottomNavLabelStyle}" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={x:Reference this}, Path=GoBudgetCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="4"
                                     Style="{StaticResource BottomNavItemStyle}">
                    <Label Text="{StaticResource IconStats}" Style="{StaticResource BottomNavIconStyle}" />
                    <Label Text="Stats" Style="{StaticResource BottomNavLabelStyle}" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={x:Reference this}, Path=GoStatsCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="5"
                                     Style="{StaticResource BottomNavItemStyle}">
                    <Label Text="{StaticResource IconCalendar}" Style="{StaticResource BottomNavIconStyle}" />
                    <Label Text="Calendrier" Style="{StaticResource BottomNavLabelStyle}" FontSize="9" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={x:Reference this}, Path=GoCalendarCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Border WidthRequest="64"
                HeightRequest="64"
                BackgroundColor="{StaticResource Accent}"
                HorizontalOptions="Center"
                VerticalOptions="Start"
                Stroke="#FFFFFF"
                StrokeThickness="4"
                TranslationY="-2"
                SemanticProperties.Description="Ajouter une dépense">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="32" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#33000000"
                        Offset="0,8"
                        Radius="18"
                        Opacity="0.28" />
            </Border.Shadow>
            <Label Text="{StaticResource IconAdd}"
                   FontFamily="MaterialIcons"
                   FontSize="34"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding Source={x:Reference this}, Path=GoAddExpenseCommand}" />
            </Border.GestureRecognizers>
        </Border>
    </Grid>

</ContentView>
