<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MoneyMate.Components.AuthenticatedFooter"
             x:Name="this">

    <Border BackgroundColor="{StaticResource Secondary}"
            Padding="8,10">
        <Grid ColumnDefinitions="*,*,*,*"
              HorizontalOptions="Fill">

            <!-- Accueil -->
            <VerticalStackLayout Grid.Column="0" Spacing="3" HorizontalOptions="Center">
                <Label Text="{StaticResource IconHome}"
                       FontFamily="MaterialIcons"
                       FontSize="26"
                       TextColor="{StaticResource TextLight}"
                       HorizontalOptions="Center" />
                <Label Text="Accueil"
                       FontSize="11"
                       TextColor="{StaticResource TextLight}"
                       HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Source={x:Reference this}, Path=GoHomeCommand}" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Depenses -->
            <VerticalStackLayout Grid.Column="1" Spacing="3" HorizontalOptions="Center">
                <Label Text="{StaticResource IconExpense}"
                       FontFamily="MaterialIcons"
                       FontSize="26"
                       TextColor="{StaticResource TextLight}"
                       HorizontalOptions="Center" />
                <Label Text="Dépenses"
                       FontSize="11"
                       TextColor="{StaticResource TextLight}"
                       HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Source={x:Reference this}, Path=GoExpensesCommand}" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Budget -->
            <VerticalStackLayout Grid.Column="2" Spacing="3" HorizontalOptions="Center">
                <Label Text="{StaticResource IconBudget}"
                       FontFamily="MaterialIcons"
                       FontSize="26"
                       TextColor="{StaticResource TextLight}"
                       HorizontalOptions="Center" />
                <Label Text="Budget"
                       FontSize="11"
                       TextColor="{StaticResource TextLight}"
                       HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Source={x:Reference this}, Path=GoBudgetCommand}" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Profil -->
            <VerticalStackLayout Grid.Column="3" Spacing="3" HorizontalOptions="Center">
                <Label Text="{StaticResource IconProfile}"
                       FontFamily="MaterialIcons"
                       FontSize="26"
                       TextColor="{StaticResource TextLight}"
                       HorizontalOptions="Center" />
                <Label Text="Profil"
                       FontSize="11"
                       TextColor="{StaticResource TextLight}"
                       HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Source={x:Reference this}, Path=GoProfileCommand}" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>
    </Border>

</ContentView>
