<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MoneyMate.Components.AuthenticatedHeader"
             x:Name="this">

    <Border BackgroundColor="{StaticResource Primary}"
            StrokeThickness="0"
            Padding="18,12,18,8">
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="12"
              MinimumHeightRequest="56">
            <Grid Grid.Column="0"
                  ColumnDefinitions="Auto,Auto"
                  ColumnSpacing="8"
                  VerticalOptions="Center">
                <Button Text="{StaticResource IconBack}"
                        FontFamily="MaterialIcons"
                        Command="{Binding Source={x:Reference this}, Path=BackCommand}"
                        IsVisible="{Binding Source={x:Reference this}, Path=ShowBackButton}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextLight}"
                        FontSize="24"
                        WidthRequest="44"
                        HeightRequest="44"
                        Padding="0"
                        CornerRadius="22"
                        SemanticProperties.Description="Retour" />

                <Image Grid.Column="1"
                       Source="money_mate_icon.png"
                       WidthRequest="34"
                       HeightRequest="34"
                       VerticalOptions="Center" />
            </Grid>

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="0"
                                 VerticalOptions="Center">
                <Label Text="MoneyMate"
                       FontSize="15"
                       FontAttributes="Bold"
                        TextColor="{StaticResource TextLight}"
                       LineBreakMode="TailTruncation" />
                <Label Text="{Binding Source={x:Reference this}, Path=PageTitle}"
                       FontSize="12"
                        TextColor="{StaticResource BackgroundLight}"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <HorizontalStackLayout Grid.Column="2"
                                   Spacing="8"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center">
                <Grid WidthRequest="44"
                      HeightRequest="44"
                      SemanticProperties.Description="Alertes">
                    <Button Text="{StaticResource IconBell}"
                            FontFamily="MaterialIcons"
                            Command="{Binding Source={x:Reference this}, Path=NavigateToAlertsCommand}"
                            Style="{StaticResource IconButton}"
                            BackgroundColor="{StaticResource BackgroundLight}"
                            TextColor="{StaticResource Accent}" />
                    <BoxView WidthRequest="9"
                             HeightRequest="9"
                             CornerRadius="4.5"
                             Color="{StaticResource Danger}"
                             HorizontalOptions="End"
                             VerticalOptions="Start"
                             Margin="0,8,8,0"
                             IsVisible="{Binding Source={x:Reference this}, Path=HasNotificationBadge}" />
                </Grid>

                <Button Text="{StaticResource IconProfile}"
                        FontFamily="MaterialIcons"
                        Command="{Binding Source={x:Reference this}, Path=NavigateToProfileCommand}"
                        Style="{StaticResource IconButton}"
                        BackgroundColor="{StaticResource BackgroundLight}"
                        TextColor="{StaticResource Accent}"
                        SemanticProperties.Description="Profil" />

                <Button Text="{StaticResource IconLogout}"
                        FontFamily="MaterialIcons"
                        Command="{Binding Source={x:Reference this}, Path=LogoutCommand}"
                        Style="{StaticResource IconButton}"
                        BackgroundColor="{StaticResource BackgroundLight}"
                        TextColor="{StaticResource Danger}"
                        SemanticProperties.Description="Déconnexion" />
            </HorizontalStackLayout>
        </Grid>
    </Border>

</ContentView>
