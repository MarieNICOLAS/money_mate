<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MoneyMate.Components.AuthenticatedHeader"
             x:Name="this">

    <Border BackgroundColor="{StaticResource PrimaryLight}"
            Padding="16,12">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto"
              ColumnSpacing="10">
            <Button Text="{StaticResource IconBack}"
                    FontFamily="MaterialIcons"
                    Grid.Column="0"
                    Command="{Binding Source={x:Reference this}, Path=BackCommand}"
                    IsVisible="{Binding Source={x:Reference this}, Path=ShowBackButton}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource TextLight}"
                    FontSize="24"
                    WidthRequest="36"
                    HeightRequest="36"
                    Padding="0"
                    CornerRadius="18" />

            <Image Grid.Column="1"
                   Source="money_mate_icon.png"
                   WidthRequest="30"
                   HeightRequest="30"
                   VerticalOptions="Center" />

            <VerticalStackLayout Grid.Column="2"
                                 Spacing="0"
                                 VerticalOptions="Center">
                <Label Text="{Binding Source={x:Reference this}, Path=PageTitle}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextLight}"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <Button Grid.Column="3"
                    Text="{StaticResource IconLogout}"
                    FontFamily="MaterialIcons"
                    Command="{Binding Source={x:Reference this}, Path=LogoutCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource TextLight}"
                    FontSize="22"
                    WidthRequest="36"
                    HeightRequest="36"
                    Padding="0"
                    CornerRadius="18" />
        </Grid>
    </Border>

</ContentView>
