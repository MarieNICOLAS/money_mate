<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Container principal -->
    <Style x:Key="MainContainer" TargetType="VerticalStackLayout">
        <Setter Property="Padding" Value="16,24,16,16"/>
        <Setter Property="Spacing" Value="16"/>
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundLight}"/>
    </Style>

    <!-- Header guest -->
    <Style x:Key="HeaderGuest" TargetType="Grid">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryLight}" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <!-- Header user -->
    <Style x:Key="HeaderUser" TargetType="Grid" BasedOn="{StaticResource HeaderGuest}">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryLight}" />
    </Style>

    <!-- Footer -->
    <Style x:Key="FooterStyle" TargetType="Grid">
        <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- Styles de Page -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundLight}" />
    </Style>

    <!-- Carte -->
    <Style x:Key="CardFrame" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundLight}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="12" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="16,8" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#00000030"
                        Offset="0,3"
                        Radius="8"
                        Opacity="0.25" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Textes -->
    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="Margin" Value="16,16,16,8" />
    </Style>

    <Style x:Key="BodyText" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextDark}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="CaptionText" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
    </Style>

    <!-- Label de formulaire -->
    <Style x:Key="FormLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Secondary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Margin" Value="4,8,0,0" />
    </Style>

    <!-- Bouton principal -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="{StaticResource TextLight}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="25" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#00000040"
                        Offset="0,4"
                        Radius="25"
                        Opacity="0.35" />
            </Setter.Value>
        </Setter>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                            <Setter Property="Shadow">
                                <Setter.Value>
                                    <Shadow Brush="#00000040"
                                            Offset="0,1"
                                            Radius="12"
                                            Opacity="0.15" />
                                </Setter.Value>
                            </Setter>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                            <Setter Property="Opacity" Value="0.9" />
                            <Setter Property="Shadow">
                                <Setter.Value>
                                    <Shadow Brush="#00000033"
                                            Offset="0,3"
                                            Radius="6"
                                            Opacity="0.3" />
                                </Setter.Value>
                            </Setter>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Bouton secondaire -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource Error}" />
        <Setter Property="TextColor" Value="{StaticResource TextLight}" />
    </Style>

    <!-- Bouton outline -->
    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="TextColor" Value="{StaticResource Accent}" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="25" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#00000040"
                        Offset="0,4"
                        Radius="10"
                        Opacity="0.45" />
            </Setter.Value>
        </Setter>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                            <Setter Property="Shadow">
                                <Setter.Value>
                                    <Shadow Brush="#00000040"
                                            Offset="0,6"
                                            Radius="12"
                                            Opacity="0.5" />
                                </Setter.Value>
                            </Setter>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                            <Setter Property="Opacity" Value="0.9" />
                            <Setter Property="Shadow">
                                <Setter.Value>
                                    <Shadow Brush="#00000020"
                                            Offset="0,2"
                                            Radius="6"
                                            Opacity="0.2" />
                                </Setter.Value>
                            </Setter>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="FontFamily" Value="MaterialIcons" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="WidthRequest" Value="44" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="BackgroundColor" Value="#E8EEF3" />
        <Setter Property="TextColor" Value="{StaticResource TextDark}" />
    </Style>

    <Style x:Key="PrimaryIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="{StaticResource TextLight}" />
    </Style>

    <Style x:Key="AccentIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
        <Setter Property="TextColor" Value="{StaticResource TextLight}" />
    </Style>

    <Style x:Key="DangerIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Setter Property="BackgroundColor" Value="#FFF0F0" />
        <Setter Property="TextColor" Value="{StaticResource Error}" />
    </Style>

    <Style x:Key="BottomNavItemStyle" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="1" />
        <Setter Property="WidthRequest" Value="50" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="Padding" Value="0,4" />
    </Style>

    <Style x:Key="BottomNavIconStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MaterialIcons" />
        <Setter Property="FontSize" Value="21" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="BottomNavLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines" Value="1" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="DashboardKpiCardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="Stroke" Value="#D6E1EA" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="MinimumHeightRequest" Value="126" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="8" />
            </Setter.Value>
        </Setter>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#14000000"
                        Offset="0,4"
                        Radius="12"
                        Opacity="0.16" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton d'annulation / retour neutre -->
    <Style x:Key="CancelButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#E8EEF3" />
        <Setter Property="TextColor" Value="{StaticResource TextDark}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="25" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="MinimumHeightRequest" Value="46" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="#DCE6EE" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="#D1DEE8" />
                            <Setter Property="Opacity" Value="0.9" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.55" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="NeutralButton" TargetType="Button" BasedOn="{StaticResource CancelButton}" />

    <Style x:Key="CompactNeutralButton" TargetType="Button" BasedOn="{StaticResource CancelButton}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="MinimumHeightRequest" Value="40" />
    </Style>

    <Style x:Key="FilterChipButton" TargetType="Button">
        <Setter Property="BorderColor" Value="#D6E1EA" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="MinimumHeightRequest" Value="40" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="DashboardKpiLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource Secondary}" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines" Value="1" />
    </Style>

    <Style x:Key="DashboardKpiIconStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MaterialIcons" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="HorizontalOptions" Value="End" />
    </Style>

    <Style x:Key="DashboardKpiValueStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines" Value="2" />
    </Style>

    <Style x:Key="DashboardKpiTrendStyle" TargetType="Label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{StaticResource Secondary}" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines" Value="2" />
    </Style>

    <Style x:Key="DashboardSectionCardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="Stroke" Value="#D6E1EA" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="8" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardSectionTitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextDark}" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="DashboardQuickActionStyle" TargetType="Button">
        <Setter Property="WidthRequest" Value="138" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="BorderColor" Value="#D6E1EA" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <!-- Conteneur de champ -->
    <Style x:Key="InputContainer" TargetType="Border">
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="20" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#00000030"
                        Offset="0,3"
                        Radius="8"
                        Opacity="0.25" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Entry interieure -->
    <Style x:Key="EntryForm" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource TextDark}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Secondary}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="HeightRequest" Value="40" />
    </Style>

    <!-- Entry standard (formulaires generaux) -->
    <Style x:Key="FormEntry" TargetType="Entry" BasedOn="{StaticResource EntryForm}">
        <Setter Property="Margin" Value="16,8" />
    </Style>

</ResourceDictionary>
