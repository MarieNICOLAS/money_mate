<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                xmlns:behaviors="clr-namespace:MoneyMate.Behaviors"
                x:Class="MoneyMate.Views.Auth.LoginPage"
                Title="Connexion">

    <views:BasePage.PageContent>
        <ScrollView>
            <VerticalStackLayout Padding="30"
                                 Spacing="15"
                                 VerticalOptions="Center">
                <VerticalStackLayout.MaximumWidthRequest>
                    <OnIdiom x:TypeArguments="x:Double"
                             Phone="10000"
                             Tablet="500"
                             Desktop="500" />
                </VerticalStackLayout.MaximumWidthRequest>
                <VerticalStackLayout.HorizontalOptions>
                    <OnIdiom x:TypeArguments="LayoutOptions"
                             Phone="Fill"
                             Tablet="Center"
                             Desktop="Center" />
                </VerticalStackLayout.HorizontalOptions>

                <Label Text="Connexion"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center" />

                <!-- EMAIL -->
                <Label Text="Email" Style="{StaticResource FormLabel}" />
                <Border x:Name="EmailBorder"
                        Style="{StaticResource InputContainer}">
                    <Entry x:Name="EmailEntry"
                           Placeholder="Adresse e-mail"
                           Keyboard="Email"
                           Text="{Binding Email}"
                           Style="{StaticResource EntryForm}">
                        <Entry.Behaviors>
                            <behaviors:EmailValidationBehavior
                                Border="{x:Reference EmailBorder}"
                                ErrorLabel="{x:Reference EmailErrorLabel}" />
                        </Entry.Behaviors>
                    </Entry>
                </Border>
                <Label x:Name="EmailErrorLabel"
                       Text="Format d'email invalide"
                       TextColor="{StaticResource Error}"
                       FontSize="12"
                       Margin="4,-8,0,0"
                       IsVisible="False" />

                <!-- MOT DE PASSE -->
                <Label Text="Mot de passe" Style="{StaticResource FormLabel}" />
                <Border x:Name="PasswordBorder"
                        Style="{StaticResource InputContainer}">
                    <Grid ColumnDefinitions="*,Auto"
                          VerticalOptions="Center">
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Mot de passe"
                               IsPassword="True"
                               Text="{Binding Password}"
                               Style="{StaticResource EntryForm}">
                            <Entry.Behaviors>
                                <behaviors:PasswordMinLengthBehavior
                                    Border="{x:Reference PasswordBorder}"
                                    ErrorLabel="{x:Reference PasswordErrorLabel}" />
                            </Entry.Behaviors>
                        </Entry>
                        <Label x:Name="EyeIcon"
                               Grid.Column="1"
                               Text="{StaticResource IconEyeOpen}"
                               FontFamily="MaterialIcons"
                               FontSize="22"
                               TextColor="{StaticResource Secondary}"
                               VerticalOptions="Center"
                               Margin="5,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTogglePasswordVisibility" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>
                <Label x:Name="PasswordErrorLabel"
                       Text="Minimum 8 caracteres requis"
                       TextColor="{StaticResource Error}"
                       FontSize="8"
                       Margin="4,-8,0,0"
                       IsVisible="False" />

                <!-- Se souvenir de moi -->
                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="4"
                                       Margin="0,10,0,10">
                    <CheckBox x:Name="RememberMeCheckBox"
                              IsChecked="{Binding RememberMe}"
                              Color="{StaticResource Primary}" />
                    <Label Text="Se souvenir de moi"
                           TextColor="{StaticResource TextDark}" />
                </HorizontalStackLayout>

                <Button Text="Se connecter"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}" />

                <Label x:Name="LoginErrorLabel"
                       Text="{Binding LoginErrorMessage}"
                       TextColor="{StaticResource Error}"
                       FontSize="13"
                       HorizontalOptions="Center"
                       IsVisible="{Binding IsLoginErrorVisible}" />

                <!-- Lien inscription -->
                <HorizontalStackLayout HorizontalOptions="Center">
                    <Label Text="Pas encore de compte ? " />
                    <Label Text="S'inscrire"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGoToRegisterTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <Button Text="Retour"
                        Style="{StaticResource OutlineButton}"
                        Clicked="OnBackClicked" />

            </VerticalStackLayout>
        </ScrollView>
    </views:BasePage.PageContent>

</views:BasePage>
