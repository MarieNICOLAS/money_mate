<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                xmlns:components="clr-namespace:MoneyMate.Components"
                xmlns:viewModels="clr-namespace:MoneyMate.ViewModels.Budgets"
                x:Class="MoneyMate.Views.Budgets.BudgetsOverviewPage"
                x:Name="Page"
                x:DataType="viewModels:BudgetsOverviewViewModel"
                Title="Budgets"
                UseAuthenticatedFooter="True">
    <views:BasePage.PageContent>
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="20" Padding="24">
                <Label Text="{Binding PageTitle}"
                       Style="{StaticResource PageTitle}" />

                <VerticalStackLayout Grid.Row="1" Spacing="12">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Surveillez vos enveloppes et les catégories à risque."
                                   TextColor="{StaticResource Secondary}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="{StaticResource IconAdd}"
                                Command="{Binding AddBudgetCommand}"
                                Style="{StaticResource AccentIconButton}"
                                SemanticProperties.Description="Ajouter un budget" />
                        <Button Grid.Column="2"
                                Text="{StaticResource IconRefresh}"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource PrimaryIconButton}"
                                SemanticProperties.Description="Actualiser les budgets" />
                    </Grid>

                    <Button Text="Gérer les catégories"
                            Command="{Binding ManageCategoriesCommand}"
                            Style="{StaticResource NeutralButton}" />
                </VerticalStackLayout>

                <Label Grid.Row="2"
                       Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       TextColor="#E57373"
                       FontAttributes="Bold" />

                <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Padding="16" StrokeThickness="0" BackgroundColor="#F3F8FC">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Budgets actifs" TextColor="{StaticResource Secondary}" />
                            <Label Text="{Binding ActiveBudgetsCount}" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Padding="16" StrokeThickness="0" BackgroundColor="#FFF6E9">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="À risque" TextColor="{StaticResource Secondary}" />
                            <Label Text="{Binding BudgetsAtRiskCount}" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid Grid.Row="4" ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Padding="16" StrokeThickness="0" BackgroundColor="#EEF7EE">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Budget total" TextColor="{StaticResource Secondary}" />
                            <components:AmountDisplay Amount="{Binding TotalBudgetAmount}" Devise="{Binding Devise}" FontSize="22" TextColor="{StaticResource TextDark}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Padding="16" StrokeThickness="0" BackgroundColor="#FFF0F0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Déjà consommé" TextColor="{StaticResource Secondary}" />
                            <components:AmountDisplay Amount="{Binding TotalConsumedAmount}" Devise="{Binding Devise}" FontSize="22" TextColor="{StaticResource TextDark}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <CollectionView Grid.Row="5"
                                ItemsSource="{Binding Budgets}"
                                IsVisible="{Binding HasBudgets}"
                                VerticalOptions="FillAndExpand"
                                SelectionMode="None"
                                Margin="0,0,0,12">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:BudgetOverviewItemViewModel">
                            <Border Padding="16" Margin="0,0,0,12" Stroke="#D6E1EA" StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>

                                <VerticalStackLayout Spacing="10">
                                    <components:BudgetProgressBar CategoryName="{Binding CategoryName}"
                                                                  SpentAmount="{Binding ConsumedAmount}"
                                                                  BudgetAmount="{Binding BudgetAmount}"
                                                                  Devise="{Binding Devise}" />

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <Label Grid.Column="0" Text="{Binding PeriodLabel}" TextColor="{StaticResource Secondary}" />
                                        <Label Grid.Column="1" Text="{Binding StatusText}" FontAttributes="Bold" TextColor="{StaticResource Secondary}" />
                                    </Grid>

                                    <Label Text="{Binding SummaryLabel}"
                                           TextColor="{StaticResource Secondary}"
                                           FontSize="12" />

                                    <Button Text="{StaticResource IconEdit}"
                                            Command="{Binding Source={x:Reference Page}, Path=BindingContext.OpenEditBudgetCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource IconButton}"
                                            HorizontalOptions="End"
                                            SemanticProperties.Description="Modifier le budget" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <components:EmptyStateView Grid.Row="5"
                                           IsVisible="{Binding HasBudgets, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                           Icon="📊"
                                           Message="Aucun budget actif pour le moment."
                                           ActionText="Créer un budget"
                                           ActionCommand="{Binding AddBudgetCommand}" />
        </Grid>
    </views:BasePage.PageContent>
</views:BasePage>
