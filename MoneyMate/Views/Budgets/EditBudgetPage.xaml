<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                xmlns:viewModels="clr-namespace:MoneyMate.ViewModels.Budgets"
                x:Class="MoneyMate.Views.Budgets.EditBudgetPage"
                x:Name="Page"
                x:DataType="viewModels:BudgetFormViewModel"
                Title="Modifier le budget"
                UseAuthenticatedFooter="True">
    <views:BasePage.PageContent>
        <ScrollView>
            <VerticalStackLayout Style="{StaticResource MainContainer}" Spacing="18">
                <Label Text="{Binding PageTitle}"
                       Style="{StaticResource PageTitle}" />

                <Border Style="{StaticResource CardFrame}" Margin="0,0,0,8">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Parametres du budget"
                               Style="{StaticResource SectionTitle}" />

                        <Label Text="Montant"
                               Style="{StaticResource FormLabel}" />
                        <Border Style="{StaticResource InputContainer}">
                            <Entry Text="{Binding AmountText, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   Placeholder="0,00"
                                   Style="{StaticResource EntryForm}" />
                        </Border>

                        <Label Text="Mois du budget"
                               Style="{StaticResource FormLabel}" />
                        <Border Style="{StaticResource InputContainer}">
                            <Picker ItemsSource="{Binding MonthOptions}"
                                    ItemDisplayBinding="{Binding Label}"
                                    SelectedItem="{Binding SelectedMonth, Mode=TwoWay}"
                                    Title="Choisissez un mois" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Etat"
                               Style="{StaticResource SectionTitle}" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Switch IsToggled="{Binding IsActive, Mode=TwoWay}" />
                            <Label Grid.Column="1"
                                   Text="Conserver ce budget actif"
                                   VerticalTextAlignment="Center"
                                   TextColor="{StaticResource TextDark}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding ValidationMessage}"
                       IsVisible="{Binding HasValidationErrors}"
                       TextColor="{StaticResource Error}"
                       FontAttributes="Bold" />

                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       TextColor="{StaticResource Error}"
                       FontAttributes="Bold" />

                <Grid ColumnDefinitions="*,Auto,*"
                      ColumnSpacing="12"
                      Margin="0,8,0,0">
                    <Button Grid.Column="0"
                            Text="{StaticResource IconDelete}"
                            Command="{Binding DeleteCommand}"
                            IsVisible="{Binding CanDelete}"
                            Style="{StaticResource DangerIconButton}"
                            SemanticProperties.Description="Supprimer le budget" />
                    <Button Grid.Column="1"
                            Text="Annuler"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource OutlineButton}" />
                    <Button Grid.Column="2"
                            Text="Enregistrer"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding CanSave}"
                            Style="{StaticResource PrimaryButton}" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </views:BasePage.PageContent>
</views:BasePage>
