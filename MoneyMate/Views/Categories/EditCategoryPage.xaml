<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                xmlns:components="clr-namespace:MoneyMate.Components"
                xmlns:converters="clr-namespace:MoneyMate.Converters"
                 xmlns:viewModels="clr-namespace:MoneyMate.ViewModels.Categories"
                x:Class="MoneyMate.Views.Categories.EditCategoryPage"
                x:Name="Page"
                 x:DataType="viewModels:CategoryFormViewModel"
                Title="Modifier la catégorie"
                UseAuthenticatedFooter="True">

    <views:BasePage.Resources>
        <ResourceDictionary>
            <converters:HexToColorConverter x:Key="HexToColorConverter" />
        </ResourceDictionary>
    </views:BasePage.Resources>

    <views:BasePage.PageContent>
        <ScrollView>
            <VerticalStackLayout Style="{StaticResource MainContainer}">
                <Label Text="{Binding PageTitle}"
                       Style="{StaticResource PageTitle}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="Modifiez cette catégorie pour votre espace."
                           Style="{StaticResource BodyText}"
                           TextColor="{StaticResource Secondary}" />
                </VerticalStackLayout>

                <Border Style="{StaticResource CardFrame}"
                        Margin="0">
                    <VerticalStackLayout Spacing="16">

                        <Label Text="Aperçu"
                               Style="{StaticResource SectionTitle}"
                               Margin="0" />

                        <components:CategoryBadge CategoryName="{Binding Name}"
                                                  CategoryIcon="{Binding Icon}"
                                                  CategoryColor="{Binding ColorHex, Converter={StaticResource HexToColorConverter}}" />

                        <Label Text="Les modifications d'une catégorie système sont enregistrées uniquement pour votre utilisateur."
                               Style="{StaticResource CaptionText}"
                               TextColor="{StaticResource Secondary}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardFrame}"
                        Margin="0">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Informations"
                               Style="{StaticResource SectionTitle}"
                               Margin="0" />

                        <Label Text="Nom"
                               Style="{StaticResource FormLabel}" />
                        <Border Style="{StaticResource InputContainer}">
                            <Entry Text="{Binding Name}"
                                   Placeholder="Ex. Alimentation"
                                   Style="{StaticResource EntryForm}"
                                   ClearButtonVisibility="WhileEditing" />
                        </Border>

                        <Label Text="Description"
                               Style="{StaticResource FormLabel}" />
                        <Border Style="{StaticResource InputContainer}">
                            <Editor Text="{Binding Description}"
                                    Placeholder="Description optionnelle"
                                    TextColor="{StaticResource TextDark}"
                                    PlaceholderColor="{StaticResource Secondary}"
                                    BackgroundColor="Transparent"
                                    FontSize="15"
                                    AutoSize="TextChanges"
                                    MinimumHeightRequest="100" />
                        </Border>

                        <Label Text="Icône"
                               Style="{StaticResource FormLabel}" />

                        <Border Style="{StaticResource InputContainer}">
                            <Entry Text="{Binding Icon}"
                                   Placeholder="Ex. 💰"
                                   Style="{StaticResource EntryForm}"
                                   ClearButtonVisibility="WhileEditing" />
                        </Border>

                        <FlexLayout BindableLayout.ItemsSource="{Binding AvailableIconOptions}"
                                    Direction="Row"
                                    Wrap="Wrap"
                                    JustifyContent="Start"
                                    AlignItems="Start">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:CategorySelectionOptionViewModel">
                                    <Border Padding="8"
                                            Margin="4"
                                            BackgroundColor="#F3F8FC"
                                            StrokeThickness="2"
                                            Stroke="#D6E1EA">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding SelectCommand}" />
                                        </Border.GestureRecognizers>

                                        <Label Text="{Binding Value}"
                                               FontSize="24"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>

                        <Label Text="Couleur"
                               Style="{StaticResource FormLabel}" />

                        <FlexLayout BindableLayout.ItemsSource="{Binding AvailableColorOptions}"
                                    Direction="Row"
                                    Wrap="Wrap"
                                    JustifyContent="Start"
                                    AlignItems="Start">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:CategorySelectionOptionViewModel">
                                    <Border Padding="4"
                                            Margin="4"
                                            Stroke="#D6E1EA"
                                            StrokeThickness="2">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="20" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding SelectCommand}" />
                                        </Border.GestureRecognizers>

                                        <Border WidthRequest="34"
                                                HeightRequest="34"
                                                BackgroundColor="{Binding Value, Converter={StaticResource HexToColorConverter}}"
                                                StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="17" />
                                            </Border.StrokeShape>
                                        </Border>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12"
                              VerticalOptions="Center">
                            <Switch IsToggled="{Binding IsActive}"
                                    OnColor="{StaticResource Success}" />
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label Text="Catégorie active"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextDark}" />
                                <Label Text="Vous pouvez désactiver temporairement une catégorie sans la supprimer."
                                       Style="{StaticResource CaptionText}"
                                       TextColor="{StaticResource Secondary}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12"
                              VerticalOptions="Center">
                            <Switch IsToggled="{Binding EnableCategoryAlert}"
                                    OnColor="{StaticResource Accent}" />
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label Text="Alerte de catégorie"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextDark}" />
                                <Label Text="Activez un seuil optionnel pour cette catégorie."
                                       Style="{StaticResource CaptionText}"
                                       TextColor="{StaticResource Secondary}" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="12"
                                             IsVisible="{Binding EnableCategoryAlert}">
                            <Label Text="Seuil (%)"
                                   Style="{StaticResource FormLabel}" />
                            <Border Style="{StaticResource InputContainer}">
                                <Entry Text="{Binding CategoryAlertThresholdPercentageText}"
                                       Placeholder="80"
                                       Style="{StaticResource EntryForm}"
                                       Keyboard="Numeric"
                                       ClearButtonVisibility="WhileEditing" />
                            </Border>

                            <Label Text="Message"
                                   Style="{StaticResource FormLabel}" />
                            <Border Style="{StaticResource InputContainer}">
                                <Editor Text="{Binding CategoryAlertMessage}"
                                        Placeholder="Message optionnel"
                                        TextColor="{StaticResource TextDark}"
                                        PlaceholderColor="{StaticResource Secondary}"
                                        BackgroundColor="Transparent"
                                        FontSize="15"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="80" />
                            </Border>
                        </VerticalStackLayout>

                        <Label Text="{Binding ValidationMessage}"
                               IsVisible="{Binding HasValidationErrors}"
                               TextColor="{StaticResource Error}"
                               FontAttributes="Bold" />

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Primary}" />

                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="12">

                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsEditMode}"
                                         Value="True">
                                <Setter Property="Text"
                                        Value="Enregistrer les modifications" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsEditMode}"
                                         Value="False">
                                <Setter Property="Text"
                                        Value="Enregistrer" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Text="{StaticResource IconDelete}"
                            Command="{Binding DeleteCommand}"
                            IsVisible="{Binding CanDelete}"
                            Style="{StaticResource DangerIconButton}"
                            SemanticProperties.Description="Supprimer la catégorie" />

                    <Button Text="Annuler"
                            Style="{StaticResource OutlineButton}"
                            Command="{Binding CancelCommand}" />

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </views:BasePage.PageContent>
</views:BasePage>
