<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                xmlns:components="clr-namespace:MoneyMate.Components"
                x:Class="MoneyMate.Views.Dashboard.DashboardPage"
                Title="Tableau de Bord"
                ShowHeader="False"
                ShowFooter="False">

    <views:BasePage.PageContent>
        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Header authentifié -->
            <components:AuthenticatedHeader Grid.Row="0"
                                            UserName="{Binding UserName}"
                                            LogoutCommand="{Binding LogoutCommand}" />

            <!-- Contenu principal -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Spacing="20" Padding="30">
                    <Label Text="Bienvenue sur votre tableau de bord !"
                           Style="{StaticResource PageTitle}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </ScrollView>

            <!-- Footer authentifié -->
            <components:AuthenticatedFooter Grid.Row="2"
                                            GoHomeCommand="{Binding GoHomeCommand}"
                                            GoExpensesCommand="{Binding GoExpensesCommand}"
                                            GoBudgetCommand="{Binding GoBudgetCommand}"
                                            GoProfileCommand="{Binding GoProfileCommand}" />

        </Grid>
    </views:BasePage.PageContent>

</views:BasePage>
