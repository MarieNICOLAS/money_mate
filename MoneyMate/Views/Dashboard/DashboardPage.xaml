<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                xmlns:components="clr-namespace:MoneyMate.Components"
                xmlns:viewModels="clr-namespace:MoneyMate.ViewModels.Dashboard"
                x:Class="MoneyMate.Views.Dashboard.DashboardPage"
                x:DataType="viewModels:DashboardViewModel"
                Title="Tableau de bord"
                ShowFooter="False"
                ShowAuthenticatedBackButton="False"
                UseAuthenticatedFooter="True">

    <views:BasePage.PageContent>
            <ScrollView>
                <VerticalStackLayout Spacing="20" Padding="24,20,24,32">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Bonjour"
                                   TextColor="{StaticResource Secondary}" />
                            <Label Text="{Binding UserName}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextDark}" />
                            <Label Text="Voici la synthèse actuelle de vos finances." TextColor="{StaticResource Secondary}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="{StaticResource IconRefresh}"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource PrimaryIconButton}"
                                SemanticProperties.Description="Actualiser le tableau de bord" />
                    </Grid>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}" />

                    <Label Text="{Binding ErrorMessage}"
                           IsVisible="{Binding HasError}"
                           TextColor="#E57373"
                           FontAttributes="Bold" />

                    <Border Padding="18" Stroke="#D6E1EA" StrokeThickness="1" BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="16">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Budget du mois"
                                       TextColor="{StaticResource Secondary}"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding CurrentMonthBudgetDisplay}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" />
                            </VerticalStackLayout>

                            <Grid HorizontalOptions="Center"
                                  VerticalOptions="Center">
                                <components:DonutChartView Segments="{Binding TopCategorySegments}"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center" />

                                <VerticalStackLayout HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Spacing="2">
                                    <Label Text="Solde actuel"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{StaticResource Secondary}" />
                                    <Label Text="{Binding CurrentMonthBalanceDisplay}"
                                           HorizontalTextAlignment="Center"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Accent}" />
                                </VerticalStackLayout>
                            </Grid>

                            <VerticalStackLayout Spacing="10"
                                                 IsVisible="{Binding HasTopCategories}"
                                                 BindableLayout.ItemsSource="{Binding TopCategories}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:DashboardCategoryItemViewModel">
                                        <Border Padding="14" Stroke="#D6E1EA" StrokeThickness="1" BackgroundColor="White">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>

                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  RowDefinitions="Auto,Auto"
                                                  ColumnSpacing="12"
                                                  RowSpacing="4">
                                                <BoxView Grid.RowSpan="2"
                                                         WidthRequest="10"
                                                         HeightRequest="48"
                                                         VerticalOptions="Center"
                                                         Color="{Binding SegmentColor}" />

                                                <Label Grid.Column="1"
                                                       Text="{Binding CategoryName}"
                                                       FontAttributes="Bold"
                                                       FontSize="16" />

                                                <Label Grid.Column="2"
                                                       Text="{Binding AmountDisplay}"
                                                       FontAttributes="Bold"
                                                       FontSize="15"
                                                       TextColor="{StaticResource Accent}" />

                                                <Label Grid.Row="1"
                                                       Grid.Column="1"
                                                       Text="{Binding ExpensesCountText}"
                                                       TextColor="{StaticResource Secondary}" />

                                                <Label Grid.Row="1"
                                                       Grid.Column="2"
                                                       Text="{Binding PercentageDisplay}"
                                                       TextColor="{StaticResource Secondary}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <components:EmptyStateView IsVisible="{Binding HasTopCategories, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                                       Icon="📭"
                                                       Message="Aucune dépense à afficher pour ce mois." />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <Button Grid.Column="0"
                                Text="Calendrier"
                                Command="{Binding OpenCalendarCommand}"
                                BackgroundColor="#F3F8FC"
                                TextColor="{StaticResource TextDark}" />
                        <Button Grid.Column="1"
                                Text="Charges fixes"
                                Command="{Binding OpenFixedChargesCommand}"
                                BackgroundColor="#EEF7EE"
                                TextColor="{StaticResource TextDark}" />
                        <Button Grid.Column="2"
                                Text="Alertes"
                                Command="{Binding OpenAlertsCommand}"
                                BackgroundColor="#FFF6E9"
                                TextColor="{StaticResource TextDark}" />
                    </Grid>

                    <Label Text="Transactions récentes"
                           Style="{StaticResource SectionTitle}" />

                    <VerticalStackLayout Spacing="10"
                                         IsVisible="{Binding HasRecentTransactions}"
                                         BindableLayout.ItemsSource="{Binding RecentTransactions}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:RecentTransactionItemViewModel">
                                <Border Padding="14" Stroke="#D6E1EA" StrokeThickness="1" BackgroundColor="White">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>

                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          RowDefinitions="Auto,Auto"
                                          ColumnSpacing="12"
                                          RowSpacing="4">
                                        <Border Grid.RowSpan="2"
                                                WidthRequest="42"
                                                HeightRequest="42"
                                                BackgroundColor="{Binding AccentColor}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="21" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding Icon}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   FontSize="18" />
                                        </Border>

                                        <Label Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontAttributes="Bold"
                                               LineBreakMode="TailTruncation" />

                                        <Label Grid.Column="2"
                                               Text="{Binding AmountDisplay}"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Accent}" />

                                        <Label Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding Subtitle}"
                                               TextColor="{StaticResource Secondary}"
                                               LineBreakMode="TailTruncation" />

                                        <Label Grid.Row="1"
                                               Grid.Column="2"
                                               Text="{Binding DateDisplay}"
                                               TextColor="{StaticResource Secondary}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <components:EmptyStateView IsVisible="{Binding HasRecentTransactions, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                               Icon="🧾"
                                               Message="Aucune transaction récente à afficher." />
                </VerticalStackLayout>
            </ScrollView>
    </views:BasePage.PageContent>

</views:BasePage>
