<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                x:Class="MoneyMate.Views.Expenses.AddExpensePage"
                Title="Ajouter une dépense"
                UseAuthenticatedFooter="True">
    <views:BasePage.PageContent>
        <ScrollView>
            <VerticalStackLayout Style="{StaticResource MainContainer}" Spacing="18">
                <Label Text="Nouvelle dépense"
                       Style="{StaticResource PageTitle}"
                       Margin="0,8,0,0" />

                <Border Style="{StaticResource CardFrame}" Margin="0,0,0,8">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Informations principales"
                               Style="{StaticResource SectionTitle}" />

                        <Label Text="Montant"
                               Style="{StaticResource FormLabel}" />
                        <Border Style="{StaticResource InputContainer}">
                            <Entry Text="{Binding AmountText, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   Placeholder="0,00"
                                   Style="{StaticResource EntryForm}" />
                        </Border>

                        <Label Text="Date"
                               Style="{StaticResource FormLabel}" />
                        <DatePicker Date="{Binding ExpenseDate, Mode=TwoWay}" />

                        <Label Text="Catégorie"
                               Style="{StaticResource FormLabel}" />
                        <Picker ItemsSource="{Binding AvailableCategories}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                Title="Sélectionnez une catégorie" />

                        <Label Text="Notes"
                               Style="{StaticResource FormLabel}" />
                        <Border Style="{StaticResource InputContainer}">
                            <Editor Text="{Binding Description, Mode=TwoWay}"
                                    Placeholder="Ajoutez un contexte ou un détail"
                                    AutoSize="TextChanges"
                                    MinimumHeightRequest="90" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Options"
                               Style="{StaticResource SectionTitle}" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Switch IsToggled="{Binding IsRecurring, Mode=TwoWay}" />
                            <Label Grid.Column="1"
                                   Text="Marquer cette dépense comme récurrente"
                                   VerticalTextAlignment="Center"
                                   TextColor="{StaticResource TextDark}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       TextColor="{StaticResource Error}"
                       FontAttributes="Bold" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,8,0,0">
                    <Button Grid.Column="0"
                            Text="Annuler"
                            Command="{Binding CancelCommand}"
                            BackgroundColor="#E8EEF3"
                            TextColor="{StaticResource TextDark}" />
                    <Button Grid.Column="1"
                            Text="Enregistrer"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding CanSave}"
                            Style="{StaticResource PrimaryButton}" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </views:BasePage.PageContent>
</views:BasePage>
