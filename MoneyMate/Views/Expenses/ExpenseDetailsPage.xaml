<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                xmlns:components="clr-namespace:MoneyMate.Components"
                xmlns:viewModels="clr-namespace:MoneyMate.ViewModels.Expenses"
                x:Class="MoneyMate.Views.Expenses.ExpenseDetailsPage"
                x:Name="Page"
                x:DataType="viewModels:ExpenseDetailsViewModel"
                Title="Détail de la dépense"
                UseAuthenticatedFooter="True">
    <views:BasePage.PageContent>
        <ScrollView>
            <VerticalStackLayout Style="{StaticResource MainContainer}" Spacing="18">
                <Label Text="{Binding Source={x:Reference Page}, Path=PageTitle}"
                       Style="{StaticResource PageTitle}" />

                <Border Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding CategoryName}"
                                       Style="{StaticResource SectionTitle}" />
                                <Label Text="{Binding ExpenseDate, StringFormat='Le {0:dd/MM/yyyy}'}"
                                       TextColor="{StaticResource Secondary}" />
                            </VerticalStackLayout>

                            <components:AmountDisplay Grid.Column="1"
                                                      Amount="{Binding Amount}"
                                                      Devise="{Binding Devise}"
                                                      FontSize="24"
                                                      TextColor="{StaticResource Accent}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Grid.Column="0" Padding="12" StrokeThickness="0" BackgroundColor="#F3F8FC">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Type" TextColor="{StaticResource Secondary}" />
                                    <Label Text="{Binding ExpenseTypeText}" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" Padding="12" StrokeThickness="0" BackgroundColor="#EEF7EE">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Créée le" TextColor="{StaticResource Secondary}" />
                                    <Label Text="{Binding CreatedAt, StringFormat='{0:dd/MM/yyyy HH:mm}'}" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Label Text="Description"
                               Style="{StaticResource FormLabel}" />
                        <Border Style="{StaticResource InputContainer}">
                            <Label Text="{Binding Description}"
                                   TextColor="{StaticResource TextDark}"
                                   LineBreakMode="WordWrap" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       TextColor="{StaticResource Error}"
                       FontAttributes="Bold" />

                <VerticalStackLayout Spacing="12" Margin="0,8,0,0">
                    <Button Text="{StaticResource IconEdit}"
                            Command="{Binding EditCommand}"
                            Style="{StaticResource PrimaryIconButton}"
                            HorizontalOptions="End"
                            SemanticProperties.Description="Modifier la dépense" />
                    <Button Text="Dupliquer"
                            Command="{Binding DuplicateCommand}"
                            BackgroundColor="#E8EEF3"
                            TextColor="{StaticResource TextDark}" />
                    <Button Text="{StaticResource IconDelete}"
                            Command="{Binding DeleteCommand}"
                            Style="{StaticResource DangerIconButton}"
                            HorizontalOptions="End"
                            SemanticProperties.Description="Supprimer la dépense" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </views:BasePage.PageContent>
</views:BasePage>
