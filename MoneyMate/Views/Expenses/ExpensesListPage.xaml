<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                xmlns:components="clr-namespace:MoneyMate.Components"
                xmlns:viewModels="clr-namespace:MoneyMate.ViewModels.Expenses"
                x:Class="MoneyMate.Views.Expenses.ExpensesListPage"
                x:Name="Page"
                x:DataType="viewModels:ExpensesListViewModel"
                Title="Dépenses"
                UseAuthenticatedFooter="True">
    <views:BasePage.PageContent>
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
              RowSpacing="20"
              Padding="24">
                <Label Text="{Binding Source={x:Reference Page}, Path=PageTitle}"
                       Style="{StaticResource PageTitle}" />

                <Grid Grid.Row="1"
                      ColumnDefinitions="*,Auto,Auto,Auto"
                      ColumnSpacing="12">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="Consultez vos opérations récentes et vos totaux." TextColor="{StaticResource Secondary}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="{StaticResource IconAdd}"
                            Command="{Binding AddExpenseCommand}"
                            Style="{StaticResource AccentIconButton}"
                            SemanticProperties.Description="Ajouter une dépense" />
                    <Button Grid.Column="2"
                            Text="{StaticResource IconQuickAdd}"
                            Command="{Binding QuickAddExpenseCommand}"
                            Style="{StaticResource AccentIconButton}"
                            SemanticProperties.Description="Ajout rapide" />
                    <Button Grid.Column="3"
                            Text="{StaticResource IconRefresh}"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryIconButton}"
                            SemanticProperties.Description="Actualiser les dépenses" />
                </Grid>

                <Label Text="{Binding ErrorMessage}"
                       Grid.Row="2"
                       IsVisible="{Binding HasError}"
                       TextColor="#E57373"
                       FontAttributes="Bold" />

                <Grid Grid.Row="3"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Border Grid.Column="0" Padding="16" StrokeThickness="0" BackgroundColor="#F3F8FC">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Total" TextColor="{StaticResource Secondary}" />
                            <components:AmountDisplay Amount="{Binding TotalExpenses}"
                                                      Devise="{Binding Devise}"
                                                      FontSize="24"
                                                      TextColor="{StaticResource TextDark}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Padding="16" StrokeThickness="0" BackgroundColor="#EEF7EE">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Nombre d'opérations" TextColor="{StaticResource Secondary}" />
                            <Label Text="{Binding ExpensesCount}" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid Grid.Row="4">
                    <CollectionView ItemsSource="{Binding Expenses}"
                                    IsVisible="{Binding HasExpenses}"
                                    ItemSizingStrategy="MeasureFirstItem">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:ExpenseListItemViewModel">
                            <components:ExpenseCard ExpenseDate="{Binding ExpenseDate}"
                                                    Amount="{Binding Amount}"
                                                    Devise="{Binding Devise}"
                                                    DisplayName="{Binding DisplayName}"
                                                    CategoryName="{Binding CategoryName}"
                                                    CategoryIcon="{Binding CategoryIcon}"
                                                    CategoryColor="{Binding CategoryColor}"
                                                    Note="{Binding Note}"
                                                    TapCommand="{Binding OpenCommand}"
                                                    TapCommandParameter="{Binding .}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    </CollectionView>

                    <components:EmptyStateView IsVisible="{Binding HasExpenses, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                               Icon="💸"
                                               Message="Aucune dépense enregistrée pour le moment."
                                               ActionText="Ajouter une dépense"
                                               ActionCommand="{Binding AddExpenseCommand}" />
                </Grid>
        </Grid>
    </views:BasePage.PageContent>
</views:BasePage>
