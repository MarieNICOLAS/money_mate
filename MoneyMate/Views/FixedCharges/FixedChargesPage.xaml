<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                xmlns:components="clr-namespace:MoneyMate.Components"
                xmlns:viewModels="clr-namespace:MoneyMate.ViewModels.FixedCharges"
                x:Class="MoneyMate.Views.FixedCharges.FixedChargesPage"
                x:Name="Page"
                x:DataType="viewModels:FixedChargesViewModel"
                Title="Charges fixes"
                UseAuthenticatedFooter="True">
    <views:BasePage.PageContent>
        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="24">
                <Label Text="{Binding Source={x:Reference Page}, Path=PageTitle}"
                       Style="{StaticResource PageTitle}" />

                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="Suivez vos prélèvements récurrents et générez les dépenses attendues."
                               TextColor="{StaticResource Secondary}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="{StaticResource IconGenerate}"
                            Command="{Binding GenerateExpensesCommand}"
                            Style="{StaticResource AccentIconButton}"
                            SemanticProperties.Description="Générer les dépenses récurrentes" />
                    <Button Grid.Column="2"
                            Text="{StaticResource IconAdd}"
                            Command="{Binding AddFixedChargeCommand}"
                            Style="{StaticResource AccentIconButton}"
                            SemanticProperties.Description="Ajouter une charge fixe" />
                    <Button Grid.Column="3"
                            Text="{StaticResource IconRefresh}"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryIconButton}"
                            SemanticProperties.Description="Actualiser les charges fixes" />
                </Grid>

                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       TextColor="#E57373"
                       FontAttributes="Bold" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Padding="16" StrokeThickness="0" BackgroundColor="#F3F8FC">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Actives" TextColor="{StaticResource Secondary}" />
                            <Label Text="{Binding ActiveFixedChargesCount}" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Padding="16" StrokeThickness="0" BackgroundColor="#FFF6E9">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="À venir (30 jours)" TextColor="{StaticResource Secondary}" />
                            <Label Text="{Binding UpcomingFixedChargesCount}" FontSize="24" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border Padding="16" StrokeThickness="0" BackgroundColor="#EEF7EE">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Équivalent mensuel projeté" TextColor="{StaticResource Secondary}" />
                        <components:AmountDisplay Amount="{Binding ProjectedMonthlyAmount}"
                                                  Devise="{Binding Devise}"
                                                  FontSize="24"
                                                  TextColor="{StaticResource TextDark}" />
                    </VerticalStackLayout>
                </Border>

                <CollectionView ItemsSource="{Binding FixedCharges}"
                                IsVisible="{Binding HasFixedCharges}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:FixedChargeItemViewModel">
                            <Border Padding="16" Margin="0,4" Stroke="#D6E1EA" StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                                    <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="10">
                                        <components:CategoryBadge CategoryName="{Binding CategoryName}"
                                                                  CategoryIcon="{Binding CategoryIcon}"
                                                                  CategoryColor="{Binding CategoryColor}" />
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                                            <Label Text="{Binding FrequencyLabel}" TextColor="{StaticResource Secondary}" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>

                                    <components:AmountDisplay Grid.Row="0" Grid.Column="1"
                                                              Amount="{Binding Amount}"
                                                              Devise="{Binding Devise}"
                                                              FontSize="18"
                                                              TextColor="{StaticResource Accent}" />

                                    <Label Grid.Row="1" Grid.Column="0"
                                           Text="{Binding Description}"
                                           IsVisible="{Binding HasDescription}"
                                           TextColor="{StaticResource Secondary}" />

                                    <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Spacing="16">
                                        <Label Text="{Binding NextOccurrenceDate, StringFormat='Prochaine échéance : {0:dd/MM/yyyy}'}"
                                               TextColor="{StaticResource Secondary}" />
                                        <Label Text="{Binding DayOfMonth, StringFormat='Jour : {0}'}"
                                               TextColor="{StaticResource Secondary}" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Spacing="8">
                                        <Button Text="{StaticResource IconEdit}"
                                                Command="{Binding Source={x:Reference Page}, Path=BindingContext.EditFixedChargeCommand}"
                                                CommandParameter="{Binding .}"
                                                Style="{StaticResource IconButton}"
                                                SemanticProperties.Description="Modifier la charge fixe" />
                                        <Button Text="{Binding ToggleActionIcon}"
                                                Command="{Binding Source={x:Reference Page}, Path=BindingContext.ToggleFixedChargeActiveCommand}"
                                                CommandParameter="{Binding .}"
                                                Style="{StaticResource PrimaryIconButton}"
                                                SemanticProperties.Description="Activer ou désactiver la charge fixe" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <components:EmptyStateView IsVisible="{Binding HasFixedCharges, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                           Icon="📅"
                                           Message="Aucune charge fixe active pour le moment." />
            </VerticalStackLayout>
        </ScrollView>
    </views:BasePage.PageContent>
</views:BasePage>
