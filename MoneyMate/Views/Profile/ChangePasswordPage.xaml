<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                xmlns:components="clr-namespace:MoneyMate.Components"
                x:Class="MoneyMate.Views.Profile.ChangePasswordPage"
                Title="Changer le mot de passe"
                ShowHeader="False"
                ShowFooter="False">

    <views:BasePage.PageContent>
        <Grid RowDefinitions="Auto,*,Auto">

            <components:AuthenticatedHeader Grid.Row="0"
                                            UserName="{Binding UserName}"
                                            LogoutCommand="{Binding LogoutCommand}" />

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="30" Spacing="15">
                    <VerticalStackLayout.MaximumWidthRequest>
                        <OnIdiom x:TypeArguments="x:Double"
                                 Phone="10000" Tablet="500" Desktop="500" />
                    </VerticalStackLayout.MaximumWidthRequest>
                    <VerticalStackLayout.HorizontalOptions>
                        <OnIdiom x:TypeArguments="LayoutOptions"
                                 Phone="Fill" Tablet="Center" Desktop="Center" />
                    </VerticalStackLayout.HorizontalOptions>

                    <Label Text="Changer le mot de passe"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center" />

                    <!-- Ancien mot de passe -->
                    <Label Text="Mot de passe actuel" Style="{StaticResource FormLabel}" />
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="Mot de passe actuel"
                               IsPassword="True"
                               Text="{Binding OldPassword}"
                               Style="{StaticResource EntryForm}" />
                    </Border>

                    <!-- Nouveau mot de passe -->
                    <Label Text="Nouveau mot de passe" Style="{StaticResource FormLabel}" />
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="Nouveau mot de passe"
                               IsPassword="True"
                               Text="{Binding NewPassword}"
                               Style="{StaticResource EntryForm}" />
                    </Border>

                    <!-- Confirmation -->
                    <Label Text="Confirmer le nouveau mot de passe" Style="{StaticResource FormLabel}" />
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="Confirmer le nouveau mot de passe"
                               IsPassword="True"
                               Text="{Binding ConfirmNewPassword}"
                               Style="{StaticResource EntryForm}" />
                    </Border>

                    <!-- Message d'erreur -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Error}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding IsErrorVisible}" />

                    <Button Text="Valider"
                            Command="{Binding ChangePasswordCommand}"
                            Style="{StaticResource PrimaryButton}" />

                    <Button Text="Retour au profil"
                            Command="{Binding GoProfileCommand}"
                            Style="{StaticResource OutlineButton}" />

                </VerticalStackLayout>
            </ScrollView>

            <components:AuthenticatedFooter Grid.Row="2"
                                            GoHomeCommand="{Binding GoHomeCommand}"
                                            GoCalendarCommand="{Binding GoCalendarCommand}"
                                            GoQuickAddExpenseCommand="{Binding GoQuickAddExpenseCommand}"
                                            GoBudgetCommand="{Binding GoBudgetCommand}"
                                            GoProfileCommand="{Binding GoProfileCommand}" />
        </Grid>
    </views:BasePage.PageContent>

</views:BasePage>
