<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                xmlns:viewModels="clr-namespace:MoneyMate.ViewModels.Profile"
                x:Class="MoneyMate.Views.Profile.DeleteAccountPage"
                x:Name="self"
                x:DataType="viewModels:DeleteAccountViewModel"
                Title="Supprimer mon compte"
                ShowFooter="False"
                UseAuthenticatedFooter="True">

    <views:BasePage.PageContent>
            <ScrollView>
                <VerticalStackLayout Padding="30" Spacing="15">
                    <VerticalStackLayout.MaximumWidthRequest>
                        <OnIdiom x:TypeArguments="x:Double"
                                 Phone="10000" Tablet="500" Desktop="500" />
                    </VerticalStackLayout.MaximumWidthRequest>
                    <VerticalStackLayout.HorizontalOptions>
                        <OnIdiom x:TypeArguments="LayoutOptions"
                                 Phone="Fill" Tablet="Center" Desktop="Center" />
                    </VerticalStackLayout.HorizontalOptions>

                     <Label Text="{Binding PageTitle}"
                            Style="{StaticResource PageTitle}" />

                    <Border BackgroundColor="#FFF3F3"
                            Padding="16"
                            StrokeShape="RoundRectangle 12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="⚠ Attention"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Error}" />
                            <Label Text="Cette action est irréversible. Toutes vos données seront définitivement supprimées :"
                                   TextColor="{StaticResource TextDark}"
                                   FontSize="14" />
                            <Label Text="• Vos dépenses&#10;• Vos budgets&#10;• Vos catégories personnalisées&#10;• Vos alertes&#10;• Vos charges fixes"
                                   TextColor="{StaticResource TextDark}"
                                   FontSize="13"
                                   Margin="8,0,0,0" />
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="Confirmez avec votre mot de passe" Style="{StaticResource FormLabel}" />
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="Votre mot de passe"
                               IsPassword="True"
                               Text="{Binding Password}"
                               Style="{StaticResource EntryForm}" />
                    </Border>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Error}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding IsErrorVisible}" />

                    <Button Text="Supprimer définitivement"
                            Command="{Binding DeleteAccountCommand}"
                            BackgroundColor="{StaticResource Error}"
                            TextColor="{StaticResource TextLight}"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="25"
                            Padding="16,10" />

                    <Button Text="Annuler"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource OutlineButton}" />

                </VerticalStackLayout>
            </ScrollView>
    </views:BasePage.PageContent>

</views:BasePage>
