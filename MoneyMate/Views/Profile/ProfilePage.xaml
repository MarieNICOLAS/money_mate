<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:MoneyMate.Views"
                xmlns:components="clr-namespace:MoneyMate.Components"
                x:Class="MoneyMate.Views.Profile.ProfilePage"
                Title="Mon Profil"
                ShowHeader="False"
                ShowFooter="False">

    <views:BasePage.PageContent>
        <Grid RowDefinitions="Auto,*,Auto">

            <components:AuthenticatedHeader Grid.Row="0"
                                            UserName="{Binding UserName}"
                                            LogoutCommand="{Binding LogoutCommand}" />

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="30" Spacing="20">
                    <VerticalStackLayout.MaximumWidthRequest>
                        <OnIdiom x:TypeArguments="x:Double"
                                 Phone="10000" Tablet="500" Desktop="500" />
                    </VerticalStackLayout.MaximumWidthRequest>
                    <VerticalStackLayout.HorizontalOptions>
                        <OnIdiom x:TypeArguments="LayoutOptions"
                                 Phone="Fill" Tablet="Center" Desktop="Center" />
                    </VerticalStackLayout.HorizontalOptions>

                    <Label Text="Mon Profil"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center" />

                    <!-- Infos utilisateur -->
                    <Border Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Informations du compte"
                                   Style="{StaticResource SectionTitle}" />

                            <HorizontalStackLayout Spacing="8">
                                <Label Text="Email :" FontAttributes="Bold"
                                       TextColor="{StaticResource Secondary}" />
                                <Label Text="{Binding Email}"
                                       TextColor="{StaticResource TextDark}" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="8">
                                <Label Text="Devise :" FontAttributes="Bold"
                                       TextColor="{StaticResource Secondary}" />
                                <Label Text="{Binding Devise}"
                                       TextColor="{StaticResource TextDark}" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="8">
                                <Label Text="Début du cycle :" FontAttributes="Bold"
                                       TextColor="{StaticResource Secondary}" />
                                <Label Text="{Binding BudgetStartDay, StringFormat='Jour {0} du mois'}"
                                       TextColor="{StaticResource TextDark}" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="8">
                                <Label Text="Membre depuis :" FontAttributes="Bold"
                                       TextColor="{StaticResource Secondary}" />
                                <Label Text="{Binding MemberSince}"
                                       TextColor="{StaticResource TextDark}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Actions -->
                    <Button Text="Changer le mot de passe"
                            Command="{Binding GoToChangePasswordCommand}"
                            Style="{StaticResource PrimaryButton}" />

                    <Button Text="Supprimer mon compte"
                            Command="{Binding GoToDeleteAccountCommand}"
                            BackgroundColor="{StaticResource Error}"
                            TextColor="{StaticResource TextLight}"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="25"
                            Padding="16,10" />

                </VerticalStackLayout>
            </ScrollView>

            <components:AuthenticatedFooter Grid.Row="2"
                                            GoHomeCommand="{Binding GoHomeCommand}"
                                            GoCalendarCommand="{Binding GoCalendarCommand}"
                                            GoQuickAddExpenseCommand="{Binding GoQuickAddExpenseCommand}"
                                            GoBudgetCommand="{Binding GoBudgetCommand}"
                                            GoProfileCommand="{Binding GoProfileCommand}" />
        </Grid>
    </views:BasePage.PageContent>

</views:BasePage>
